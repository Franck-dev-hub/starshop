{% extends 'base.html.twig' %}

{% block title %}Starshop: Beam up some parts !{% endblock %}

{% block body %}
<h1>
    Starshop: your monopoly-busting option for Starship parts!
</h1>

<div>
    Browse though {{ ships|length }} starships !

    {% if ships|length > 2 %}
    <p>
        {# Just a comment #}
        That's shipload of ships !
    </p>
    {%  endif %}
</div>

<div>
    <h2>My ship</h2>
    <table>
        <tr>
            <th>Name</th>
            <td>{{ myShip.name|upper|lower|title }}</td>
        </tr>
        <tr>
            <th>Class</th>
            <td>{{ myShip.class }}</td>
        </tr>
        <tr>
            <th>Captain</th>
            <td>{{ myShip.captain }}</td>
        </tr>
        <tr>
            <th>Status</th>
            <td>{{ myShip.status }}</td>
        </tr>
    </table>
</div>
{% endblock %}
